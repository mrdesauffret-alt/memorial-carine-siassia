# Configuration du Mémorial Carine SIASSIA
# Copier ce fichier vers .env et remplir les valeurs

# =========================
# Base de données
# =========================
DB_HOST=localhost
DB_NAME=memorial_carine
DB_USER=root
DB_PASS=

# =========================
# Analytics et Monitoring
# =========================
# Google Analytics 4
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Hotjar pour l'analyse comportementale
HOTJAR_ID=1234567

# Sentry pour le monitoring d'erreurs
SENTRY_DSN=https://votre-dsn@sentry.io/projet

# =========================
# Sécurité
# =========================
# Token d'authentification admin
ADMIN_TOKEN=votre_token_admin_securise_32_caracteres

# Clé de chiffrement pour les données sensibles
ENCRYPTION_KEY=votre_cle_chiffrement_32_caracteres

# =========================
# Configuration de l'application
# =========================
# Environnement (development, staging, production)
APP_ENV=development

# Mode debug (true/false)
APP_DEBUG=true

# URL de base de l'application
APP_URL=http://localhost/memorial-carine-siassia

# =========================
# Email et notifications
# =========================
# Configuration SMTP pour l'envoi d'emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre-email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_app
SMTP_ENCRYPTION=tls

# Email de contact
CONTACT_EMAIL=contact@memorial-carine-siassia.com

# =========================
# Upload et stockage
# =========================
# Taille maximale d'upload (en bytes)
MAX_UPLOAD_SIZE=5242880

# Dossier d'upload
UPLOAD_PATH=uploads/

# Types de fichiers autorisés
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp

# =========================
# Limitation de taux
# =========================
# Limite pour les bougies (par IP par jour)
CANDLE_RATE_LIMIT=1

# Limite pour l'upload (par IP par heure)
UPLOAD_RATE_LIMIT=10

# Limite pour l'API (par IP par minute)
API_RATE_LIMIT=100

# =========================
# Cache et performance
# =========================
# Activer le cache (true/false)
CACHE_ENABLED=true

# Durée du cache (en secondes)
CACHE_DURATION=3600

# =========================
# Réseaux sociaux
# =========================
# Facebook App ID pour le partage
FACEBOOK_APP_ID=123456789012345

# Twitter Card (optionnel)
TWITTER_CARD=summary_large_image

# =========================
# CDN et assets externes
# =========================
# URL du CDN (optionnel)
CDN_URL=

# Activer la compression (true/false)
COMPRESSION_ENABLED=true

# =========================
# Maintenance
# =========================
# Mode maintenance (true/false)
MAINTENANCE_MODE=false

# Message de maintenance
MAINTENANCE_MESSAGE=Le site est temporairement en maintenance. Merci de votre patience.

# =========================
# Logs et debugging
# =========================
# Niveau de log (debug, info, warning, error)
LOG_LEVEL=info

# Dossier des logs
LOG_PATH=logs/

# Activer les logs d'API (true/false)
API_LOGGING=true

# =========================
# Configuration spécifique au mémorial
# =========================
# Nom de la personne
MEMORIAL_NAME=Carine SIASSIA

# Titre du site
SITE_TITLE=Mémorial Carine SIASSIA

# Description du site
SITE_DESCRIPTION=Une Étoile Qui Continue de Briller

# Nombre initial de bougies
INITIAL_CANDLE_COUNT=247

# Approuver automatiquement les souvenirs (true/false)
AUTO_APPROVE_MEMORIES=false

# Activer les notifications push (true/false)
PUSH_NOTIFICATIONS_ENABLED=false

# =========================
# Configuration de production
# =========================
# Activer HTTPS (true/false)
HTTPS_ENABLED=false

# Forcer HTTPS (true/false)
FORCE_HTTPS=false

# Domaine principal
DOMAIN=memorial-carine-siassia.page.gd

# =========================
# Backup et sauvegarde
# =========================
# Activer les sauvegardes automatiques (true/false)
AUTO_BACKUP_ENABLED=true

# Fréquence des sauvegardes (daily, weekly, monthly)
BACKUP_FREQUENCY=daily

# Dossier de sauvegarde
BACKUP_PATH=/backups/memorial-carine-siassia/

# =========================
# Configuration avancée
# =========================
# Timezone
TIMEZONE=Europe/Paris

# Locale
LOCALE=fr_FR

# Charset
CHARSET=utf8mb4

# Session lifetime (en minutes)
SESSION_LIFETIME=120

# =========================
# Configuration de développement
# =========================
# Activer les outils de développement (true/false)
DEV_TOOLS_ENABLED=false

# Activer le profiler (true/false)
PROFILER_ENABLED=false

# Activer les tests en production (true/false)
TESTS_ENABLED=false
